    "next": "16.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "ua-parser-js": "^2.0.6",
    "wavesurfer.js": "^7.11.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
